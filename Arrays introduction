#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;                 // number of elements

    int arr[n];               // array of size n
    for (int i = 0; i < n; i++) {
        cin >> arr[i];        // read elements
    }

    for (int i = n - 1; i >= 0; i--) {
        cout << arr[i];       // print in reverse
        if (i > 0) cout << " ";
    }

    return 0;
}
